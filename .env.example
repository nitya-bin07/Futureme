# ========================
# FutureMe — Environment Variables
# ========================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# JWT (change this to any random 32+ character string)
JWT_SECRET=change-this-to-a-random-32-char-string

# Encryption (change this to any random 32+ character string)
ENCRYPTION_SECRET=change-this-to-another-32-char-string

# ========================
# Email Configuration
# ========================
# Option 1: Leave empty to use Ethereal (auto test email, no setup needed)
# Option 2: Fill in Gmail credentials below
# Option 3: Use Resend/SendGrid for production

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=noreply@futureme.app

# ========================
# Notes
# ========================
# Gmail App Password setup:
# 1. Enable 2FA on your Google account
# 2. Go to Google Account → Security → App Passwords
# 3. Generate a password and paste it above

# For production use Resend:
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_USER=resend
# EMAIL_PASS=re_your_api_key
