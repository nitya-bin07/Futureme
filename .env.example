# ========================
# FutureMe — Environment Variables
# ========================
# Copy this file to backend/.env and fill in your real values.
# Windows:  copy .env.example backend\.env
# Mac/Linux: cp .env.example backend/.env
#
# NEVER commit backend/.env to GitHub — it contains real secrets.
# This file (.env.example) is safe to commit — it has no real values.

# ========================
# Server
# ========================
PORT=3001
FRONTEND_URL=http://localhost:3000

# ========================
# Security
# ========================
# Generate both with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Run it twice — use a different value for each one.
JWT_SECRET=change-this-to-a-random-64-char-string
ENCRYPTION_SECRET=change-this-to-another-random-64-char-string

# ========================
# Database (PostgreSQL)
# ========================
# Get a free database at https://neon.tech — takes 2 minutes, no credit card.
# After creating a project, copy the connection string from the dashboard.
# It looks like: postgresql://user:password@host.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/database

# Set to "require" for hosted Postgres (Neon, Supabase, Railway, Render).
# Set to "disable" only if running Postgres locally without SSL.
PGSSL=require

# ========================
# Stripe (payments)
# ========================
# Sign up free at https://stripe.com — stay in test mode while developing.
# Get your keys from: Stripe Dashboard → Developers → API Keys
# Test mode keys start with sk_test_ — safe to use, no real money.
#
# For the webhook secret:
#   Local testing: run `stripe listen --forward-to localhost:3001/api/webhooks/stripe`
#                  and copy the whsec_... value it prints.
#   Production: Stripe Dashboard → Developers → Webhooks → Add endpoint
#               → URL: https://yourbackend.com/api/webhooks/stripe
#               → Event: checkout.session.completed
#               → Copy the signing secret shown.
#
# Leave STRIPE_SECRET_KEY empty to disable payments (checkout returns 503).
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# ========================
# Email
# ========================
# Option 1 — Ethereal (default, no setup needed):
#   Leave EMAIL_USER and EMAIL_PASS empty.
#   A fake test inbox is created automatically on startup.
#   Every email "sent" prints a preview URL in the backend terminal.
#   Nothing reaches a real inbox — perfect for local development.
#
# Option 2 — Gmail (real emails, good for testing):
#   1. Enable 2-Step Verification on your Google account
#   2. Go to: Google Account → Security → App Passwords
#   3. Generate a password and paste it below
#
# Option 3 — Resend (best for production):
#   EMAIL_HOST=smtp.resend.com
#   EMAIL_PORT=587
#   EMAIL_USER=resend
#   EMAIL_PASS=re_your_api_key_here
#   Requires a verified domain at resend.com

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@futureme.app

# ========================
# Test card (Stripe test mode)
# ========================
# Card number : 4242 4242 4242 4242
# Expiry      : any future date (e.g. 12/30)
# CVC         : any 3 digits
# Name/address: anything
